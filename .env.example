# ══════════════════════════════════════════════
# TTRAKS ORIENTE — Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# ══════════════════════════════════════════════

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TUPROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Web Push (VAPID) ──────────────────────────
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxYYY
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@ttraks.com

# ── Storage ───────────────────────────────────
# Buckets públicos requeridos en Supabase Storage:
#   - tool-images    (imágenes de herramientas)
#   - evidence-images (fotos de devoluciones)
